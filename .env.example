# Copy to `.env` and fill in secrets.

# ── App ───────────────────────────────────────────────────────────────────────
PUBLIC_APP_URL=http://localhost:8080
NODE_ENV=development
# APP_ENV=development | sandbox | production (see docs/SANDBOX.md)
APP_ENV=development
# Production (Vercel): set PUBLIC_APP_URL to your live origin, e.g. https://your-domain.com
# Vercel also provides VERCEL_URL / VERCEL_PROJECT_PRODUCTION_URL as fallbacks on the server.

# ── Database (TiDB Cloud) ─────────────────────────────────────────────────────
DB_HOST=
DB_PORT=4000
DB_USER=
DB_PASSWORD=
DB_NAME=

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=
CLERK_SECRET_KEY=
# Production: use sk_live_ + pk_live_ from Clerk Dashboard (not test keys).
# Optional comma-separated extra JWT azp origins (preview URLs, etc.)
CLERK_AUTHORIZED_PARTIES=

# ── Email / SMS (optional in dev) ───────────────────────────────────────────────
RESEND_API_KEY=
SMTP_FROM=Triboo Sport <no-reply@disruptinglabs.com>
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ── Stripe (optional in dev) ──────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
VITE_STRIPE_PUBLISHABLE_KEY=
# Simulation events use the Stripe *test* kit (no Connect). Required for /events/sim/:token checkout.
STRIPE_TEST_SECRET_KEY=
STRIPE_TEST_PUBLISHABLE_KEY=
VITE_STRIPE_TEST_PUBLISHABLE_KEY=
# Cron auth for POST /api/cron/cleanup-simulations (Bearer or ?secret=)
CRON_SECRET=
# Shown on card form mandate text (Payment Element). Also update Stripe Dashboard → Business details.
STRIPE_CHECKOUT_BUSINESS_NAME=Triboo Sport
VITE_STRIPE_BUSINESS_DISPLAY_NAME=Triboo Sport

# ── Mercado Pago (marketplace / Split 1:1 — Mexico) ───────────────────────────
# Create an Online Payments app with Marketplace model in MP Developers.
# Redirect URI: {PUBLIC_APP_URL}/api/organizer/payouts/mp/oauth/callback
MP_CLIENT_ID=
MP_CLIENT_SECRET=
MP_PLATFORM_ACCESS_TOKEN=
MP_PLATFORM_PUBLIC_KEY=
# Optional AES key for encrypting seller OAuth tokens (falls back to JWT_SECRET)
MP_TOKEN_ENCRYPTION_KEY=
# Webhook: {PUBLIC_APP_URL}/api/webhooks/mercadopago

# ── Client (Vite) ─────────────────────────────────────────────────────────────
# Must be set at Vercel BUILD time (VITE_ prefix). Use pk_live_ in production.
VITE_CLERK_PUBLISHABLE_KEY=
# VITE_APP_ENV=sandbox on sandbox deploy (client banner + footer)
VITE_APP_ENV=
# Comma-separated OAuth buttons: google, facebook (apple removed — enable in Clerk first)
VITE_CLERK_OAUTH_PROVIDERS=google
VITE_PUBLIC_APP_URL=http://localhost:8080
# Production: https://www.triboosport.com | Sandbox: https://sandbox.triboosport.com (docs/SANDBOX.md)
VITE_DEFAULT_OG_IMAGE=https://disruptinglabs.com/data/athlete-hub/assets/images/og/triboo-sport-share.jpg

# Blog images use Disrupting Labs CDN — configured in server/cdnUpload.ts (no env vars).

# ── Feature flags (server) ────────────────────────────────────────────────────
# Embeddable widget platform — see docs/EMBED_WIDGET_PLATFORM.md
# off (default) | internal (staff portal preview only) | on (public embed live)
FEATURE_EMBED_WIDGET=off
