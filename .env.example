# Copy to `.env` and fill in secrets.

# ── App ───────────────────────────────────────────────────────────────────────
PUBLIC_APP_URL=http://localhost:8080
NODE_ENV=development
# Production (Vercel): set PUBLIC_APP_URL to your live origin, e.g. https://your-domain.com
# Vercel also provides VERCEL_URL / VERCEL_PROJECT_PRODUCTION_URL as fallbacks on the server.

# ── Database (TiDB Cloud) ─────────────────────────────────────────────────────
DB_HOST=
DB_PORT=4000
DB_USER=
DB_PASSWORD=
DB_NAME=

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=
CLERK_SECRET_KEY=
# Production: use sk_live_ + pk_live_ from Clerk Dashboard (not test keys).
# Optional comma-separated extra JWT azp origins (preview URLs, etc.)
CLERK_AUTHORIZED_PARTIES=

# ── Email / SMS (optional in dev) ───────────────────────────────────────────────
RESEND_API_KEY=
SMTP_FROM=Triboo Sport <no-reply@disruptinglabs.com>
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ── Stripe (optional in dev) ──────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
VITE_STRIPE_PUBLISHABLE_KEY=
# Shown on card form mandate text (Payment Element). Also update Stripe Dashboard → Business details.
STRIPE_CHECKOUT_BUSINESS_NAME=Triboo Sport
VITE_STRIPE_BUSINESS_DISPLAY_NAME=Triboo Sport

# ── Client (Vite) ─────────────────────────────────────────────────────────────
# Must be set at Vercel BUILD time (VITE_ prefix). Use pk_live_ in production.
VITE_CLERK_PUBLISHABLE_KEY=
# Comma-separated OAuth buttons: google, facebook (apple removed — enable in Clerk first)
VITE_CLERK_OAUTH_PROVIDERS=google
VITE_PUBLIC_APP_URL=http://localhost:8080
# Production example: https://www.triboosport.com
VITE_DEFAULT_OG_IMAGE=https://disruptinglabs.com/data/athlete-hub/assets/images/og/triboo-sport-share.jpg

# Blog images use Disrupting Labs CDN — configured in server/cdnUpload.ts (no env vars).
